{
  "redirects": [
    {
      "source": "/en/strategy-case-theory.html",
      "destination": "/en/estrategia-teoria-del-caso.html",
      "permanent": true
    },
    {
      "source": "/en/strategy-representative-scenarios.html",
      "destination": "/en/estrategia-escenarios-representativos.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/en/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/en",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(html|json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
